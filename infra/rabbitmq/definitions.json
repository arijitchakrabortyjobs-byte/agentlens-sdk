{
  "vhosts": [{"name": "agentlens"}],
  "permissions": [
    {
      "user": "agentlens",
      "vhost": "agentlens",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "queues": [
    {
      "name": "audit.worm.main",
      "vhost": "agentlens",
      "durable": true,
      "arguments": {
        "x-dead-letter-exchange": "audit.dlx",
        "x-message-ttl": 3600000
      }
    },
    {
      "name": "audit.worm.dlq",
      "vhost": "agentlens",
      "durable": true,
      "arguments": {}
    }
  ],
  "exchanges": [
    {
      "name": "audit.dlx",
      "vhost": "agentlens",
      "type": "direct",
      "durable": true
    }
  ],
  "bindings": [
    {
      "source": "audit.dlx",
      "vhost": "agentlens",
      "destination": "audit.worm.dlq",
      "destination_type": "queue",
      "routing_key": "audit.worm.main"
    }
  ]
}
